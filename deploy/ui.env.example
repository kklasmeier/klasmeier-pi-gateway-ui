# /etc/pivpngateway-ui/ui.env — PiSensors gateway UI
# Copy: sudo cp deploy/ui.env.example /etc/pivpngateway-ui/ui.env
#       sudo chmod 640 /etc/pivpngateway-ui/ui.env && sudo chown root:pi /etc/pivpngateway-ui/ui.env
#
# GATEWAY_API_TOKEN must match /etc/pivpngateway/api.env on piGateway (.100).
# See klasmeier-pi-gateway deploy/api.env.example.

GATEWAY_API_URL=http://192.168.1.100:8080
GATEWAY_API_TOKEN=your-secret-token-here
GATEWAY_UI_USER=admin
GATEWAY_UI_PASSWORD=change-me

# Internet Gateway Path Android app — setup QR (Settings → Mobile app)
HOME_WIFI_SSID=YourWiFiName
IPINFO_TOKEN=

# Informational only — systemd unit binds 127.0.0.1:8001 (see pivpngateway-ui.service)
UI_BIND=127.0.0.1:8001
